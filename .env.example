# Copia este archivo a .env y rellena tu key (el .env real está en .gitignore).

# API key de NVIDIA (https://build.nvidia.com → API Keys). Empieza con nvapi-
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo a usar (opcional). Por defecto: z-ai/glm-5.1
# Alternativas: meta/llama-3.3-70b-instruct, nvidia/nemotron-3-nano-30b-a3b
NVIDIA_MODEL=z-ai/glm-5.1

# Persistencia (opcional). Connection string de Postgres (Neon/Supabase).
# Sin esto, la app corre solo en memoria (sin historial). Empieza con postgresql://
DATABASE_URL=postgresql://usuario:password@host/db?sslmode=require
